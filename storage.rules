rules_version = '2';

// mugam-club Storage rules — see firestore.rules for the companion
// Firestore rules and the full rationale. Chat-media access is gated by
// cross-referencing the parent chat's `members` array in Firestore, so a
// user who was never in a chat can't read or write its files even with a
// guessed/leaked download URL.

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isChatMember(chatId) {
      return isSignedIn() &&
        request.auth.uid in
          firestore.get(/databases/(default)/documents/chats/$(chatId)).data.members;
    }

    // Single firestore.get() covering both membership and admin/creator
    // status, mirroring firestore.rules' isAdminOrCreator() — used for
    // group-avatar writes below, where both checks are needed together
    // anyway, so one lookup replaces what would otherwise be two.
    function isGroupAdmin(chatId) {
      let chat = firestore.get(/databases/(default)/documents/chats/$(chatId)).data;
      return isSignedIn() && request.auth.uid in chat.members &&
        (request.auth.uid == chat.get('createdBy', null) ||
          request.auth.uid in chat.get('admins', []));
    }

    // Server-side enforcement of the Settings screen's "Maximum file size"
    // slider (users/{uid}.maxUploadSizeMb, validated to [100, 2048] by
    // firestore.rules) — rejects an oversized upload here, before the
    // object ever reaches Storage, rather than uploading it first and
    // deleting it after (which onChatMediaUploaded's onFinalize trigger
    // would otherwise have to do, wasting the transfer and leaving a
    // window where the oversized file briefly exists). .get() with a
    // default covers both a user doc with no maxUploadSizeMb field yet
    // (pre-existing users) and, defensively, one somehow missing entirely.
    function maxUploadSizeBytes(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid))
        .data.get('maxUploadSizeMb', 100) * 1024 * 1024;
    }

    // avatars/{uid}.jpg — mugam-flutter's uploadAvatar() writes exactly
    // this filename shape (mugam-v2's own avatar upload is a dead stub
    // that always throws, so only this shape is live traffic today).
    // Readable by anyone signed in (avatars are public profile data,
    // matching users/{uid} read access) — writable only by the uid the
    // filename names.
    match /avatars/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && fileName.split('.')[0] == request.auth.uid;
    }

    // chats/{chatId}/{fileName} — mugam-flutter's flat upload shape
    // (exactly one segment under the chat, e.g. chats/{chatId}/{messageId}.
    // jpg). Beyond chat membership, the write must carry customMetadata
    // naming the real uploader/chat — this is what makes that metadata
    // trustworthy by the time onChatMediaUploaded's onFinalize trigger
    // reads it back to write a validatedUploads marker (see
    // firestore.rules): a lying client's upload is rejected here, before
    // the object ever reaches Storage, rather than after.
    match /chats/{chatId}/{fileName} {
      allow read: if isChatMember(chatId);
      allow write: if isChatMember(chatId) &&
        request.resource.metadata.uploaderUid == request.auth.uid &&
        request.resource.metadata.chatId == chatId &&
        request.resource.size <= maxUploadSizeBytes(request.auth.uid);
    }

    // chats/{chatId}/images|voice/{fileName} — mugam-v2's nested upload
    // shape. That app is frozen and can't be updated to attach the same
    // customMetadata, so this stays at the membership-only check it
    // already had; mugam-flutter never writes under this shape at all.
    match /chats/{chatId}/{subfolder}/{fileName} {
      allow read, write: if isChatMember(chatId);
    }

    // groups/{chatId}/avatar.jpg — mugam-v2's group photo. Any member can
    // read; mugam-v2's UI only shows the upload button to admins, and this
    // now re-enforces that server-side too, so a non-admin member can't
    // bypass the UI restriction via a direct API call.
    match /groups/{chatId}/{allPaths=**} {
      allow read: if isChatMember(chatId);
      allow write: if isGroupAdmin(chatId);
    }

    // market_images/, videos/ — defined as constants in mugam-v2 but
    // confirmed unused (its upload functions are dead stubs). Denied
    // outright rather than left open: nothing currently depends on a
    // rule here, so if a real feature needs one of these paths in the
    // future, it'll surface as an explicit permission-denied error to
    // fix, not a silent open surface today.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
